[tox]
isolated_build = true
envlist = {{ tox_envlist }}
min_version = 4.0
requires = tox-uv
skipsdist = true

[testenv]
uv_sync = true
deps =
    .[test{% if use_docs %},docs{% endif %}]
commands =
    pytest -m "not slow" {posargs}
passenv =
    CI
    GITHUB_*
    UV_*
    PYTHON*
setenv =
    PYTHONPATH = {toxinidir}/src
    PYTHONDONTWRITEBYTECODE = 1
